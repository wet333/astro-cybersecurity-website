---
interface Props {
    tone?: 'subtle' | 'subtle-strong' | 'default' | 'strong';
    hover?: boolean;
    interactive?: boolean;
    as?: 'div' | 'section' | 'article' | 'main' | 'aside' | 'header' | 'footer' | 'nav';
    class?: string;
}

const {
    tone = 'subtle',
    hover = false,
    interactive = false,
    as: Tag = 'div',
    class: className = '',
}: Props = Astro.props;

const toneClasses: Record<string, string> = {
    subtle: 'bg-surface border border-border',
    'subtle-strong': 'bg-surface-raised border border-border',
    default: 'glass',
    strong: 'glass-strong',
};

const baseClasses = [
    'relative rounded-card p-6 sm:p-7',
    'transition-all duration-200 ease-out',
    toneClasses[tone],
    hover ? 'hover:border-border-active hover:-translate-y-0.5' : '',
    interactive ? 'cursor-pointer' : '',
    className,
];
---

<Tag class:list={baseClasses}>
    <slot />
</Tag>
