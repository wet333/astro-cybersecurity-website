---
interface Props {
    size?: 'sm' | 'base' | 'lead' | 'lg';
    color?: 'default' | 'muted' | 'primary' | 'accent';
    as?: 'p' | 'span' | 'div' | 'small';
    class?: string;
}

const { size = 'base', color = 'default', as: Tag = 'p', class: className = '' } = Astro.props;

const sizeClasses: Record<string, string> = {
    sm: 'text-sm leading-relaxed',
    base: 'text-base leading-relaxed',
    lead: 'text-lg sm:text-xl leading-relaxed text-font/85',
    lg: 'text-lg sm:text-xl leading-relaxed',
};

const colorClasses: Record<string, string> = {
    default: 'text-font',
    muted: 'text-font/70',
    primary: 'text-primary',
    accent: 'text-accent',
};
---

<Tag class:list={[sizeClasses[size], colorClasses[color], className]}>
    <slot />
</Tag>
