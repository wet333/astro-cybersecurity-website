---
interface Props {
    color?: 'calm' | 'alert' | 'muted';
    number?: string | number;
    label?: string;
    class?: string;
}

const { color = 'calm', number, label, class: className = '' } = Astro.props;

const colorClasses: Record<string, string> = {
    calm: 'text-calm',
    alert: 'text-alert',
    muted: 'text-ink-muted',
};
---

<div class:list={['inline-flex items-center gap-3 text-mono text-[0.7rem] sm:text-xs uppercase tracking-[0.18em] font-medium', colorClasses[color], className]}>
    {number !== undefined && (
        <span class="inline-flex items-center gap-2">
            <span class="block w-6 h-px bg-current opacity-50" aria-hidden="true"></span>
            <span class="opacity-80">{number}</span>
        </span>
    )}
    {label && <span class="opacity-90"><slot /></span>}
    {!label && number === undefined && <slot />}
</div>
