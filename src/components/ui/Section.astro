---
import Separator from './Separator.astro';

interface Props {
    id?: string;
    variant?: 'locked' | 'full';
    tone?: 'default' | 'panel' | 'tinted-calm' | 'tinted-alert' | 'transparent';
    density?: 'airy' | 'normal' | 'tight';
    separator?: boolean;
    class?: string;
    background?:
        | 'none'
        | 'grid'
        | 'grid-lg'
        | 'grid-fine'
        | 'dots'
        | 'circuit'
        | 'glow-calm'
        | 'glow-alert'
        | 'glow-both'
        | 'glow-calm-strong'
        | 'glow-alert-strong'
        | 'glow-center'
        | 'noise';
    divider?: 'none' | 'top' | 'bottom' | 'both';
    edgeFade?: boolean;
}

const {
    id,
    variant = 'locked',
    tone = 'default',
    density = 'normal',
    separator = false,
    class: className = '',
    background = 'grid',
    divider = 'none',
    edgeFade = true,
} = Astro.props;

const variantClasses: Record<string, string> = {
    locked: 'mx-auto w-full max-w-6xl px-6 sm:px-8',
    full: 'w-full',
};

const toneClasses: Record<string, string> = {
    default: '',
    panel: 'bg-panel',
    'tinted-calm': 'bg-tinted-calm',
    'tinted-alert': 'bg-tinted-alert',
    transparent: '',
};

const densityClasses: Record<string, string> = {
    airy: 'py-24 sm:py-32 md:py-40',
    normal: 'py-20 sm:py-28 md:py-32',
    tight: 'py-14 sm:py-20 md:py-24',
};

const bgClasses: Record<string, string> = {
    none: '',
    grid: 'bg-grid',
    'grid-lg': 'bg-grid-lg',
    'grid-fine': 'bg-grid-fine',
    dots: 'bg-dots',
    circuit: 'bg-circuit',
    'glow-calm': 'bg-glow-calm',
    'glow-alert': 'bg-glow-alert',
    'glow-both': 'bg-glow-both',
    'glow-calm-strong': 'bg-glow-calm-strong',
    'glow-alert-strong': 'bg-glow-alert-strong',
    'glow-center': 'bg-glow-center',
    noise: 'bg-noise',
};

const finalSpacing = densityClasses[density];
const finalBg = tone === 'default' || tone === 'transparent' ? bgClasses[background] : '';
const finalTone = tone !== 'default' && tone !== 'transparent' ? toneClasses[tone] : '';

const dividerClasses = {
    none: '',
    top: 'divider-top',
    bottom: 'divider-bottom',
    both: 'divider-top divider-bottom',
};
---

<section
    id={id}
    class:list={[
        'relative scroll-mt-24 overflow-hidden',
        variantClasses[variant],
        finalSpacing,
        finalBg,
        finalTone,
        dividerClasses[divider],
        edgeFade ? 'section-fade-edges' : '',
        className,
    ]}
>
    <div class="relative z-10">
        <slot />
    </div>
</section>
{separator && <Separator />}
