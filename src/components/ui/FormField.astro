---
interface Props {
    id: string;
    name: string;
    label: string;
    type?: 'text' | 'email' | 'tel' | 'url';
    required?: boolean;
    placeholder?: string;
    rows?: number;
    value?: string;
    autocomplete?: string;
}

const {
    id,
    name,
    label,
    type = 'text',
    required = false,
    placeholder,
    rows = 5,
    value,
    autocomplete,
} = Astro.props;

const isTextarea = type === 'textarea';
const Tag = isTextarea ? 'textarea' : 'input';
const inputProps = isTextarea
    ? { id, name, rows, required, placeholder, autocomplete }
    : { id, name, type, required, placeholder, value, autocomplete };
---

<div class="flex flex-col gap-1.5">
    <label for={id} class="text-mono text-xs uppercase tracking-wider text-font/70 font-medium">
        {label}
        {required && <span class="text-primary ml-0.5">*</span>}
    </label>
    <Tag
        {...inputProps}
        class="w-full bg-surface/80 border border-primary/20 rounded px-3 py-2.5 text-font placeholder:text-font/40 focus:border-primary focus:ring-1 focus:ring-primary/40 focus:outline-none transition-colors duration-200 form-input"
    />
</div>
