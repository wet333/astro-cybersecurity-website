---
interface Props {
    variant?: 'primary' | 'cta' | 'info' | 'outline' | 'ghost';
    size?: 'sm' | 'md' | 'lg';
    as?: 'button' | 'a';
    type?: 'button' | 'submit' | 'reset';
    href?: string;
    isFullWidth?: boolean;
    label: string;
    iconLeft?: string;
    iconRight?: string;
    class?: string;
    target?: string;
    rel?: string;
}

const {
    variant = 'primary',
    size = 'md',
    as: Tag = 'button',
    type = 'button',
    href,
    isFullWidth = false,
    label,
    iconLeft,
    iconRight,
    class: className = '',
    target,
    rel,
}: Props = Astro.props;

const variantClasses: Record<string, string> = {
    primary: [
        'bg-surface-raised text-ink-text border border-border',
        'hover:border-calm/60 hover:text-ink-text hover:-translate-y-px',
    ].join(' '),
    cta: [
        'bg-alert text-white border border-alert font-semibold',
        'hover:bg-alert-soft hover:border-alert-soft hover:-translate-y-px hover:shadow-glow-alert-md',
    ].join(' '),
    info: [
        'bg-calm text-ink border border-calm font-semibold',
        'hover:bg-calm-soft hover:border-calm-soft hover:-translate-y-px hover:shadow-glow-md',
    ].join(' '),
    outline: [
        'bg-transparent text-ink-text border border-border',
        'hover:border-calm/60 hover:text-calm hover:-translate-y-px',
    ].join(' '),
    ghost: [
        'bg-transparent text-ink-muted border border-transparent',
        'hover:text-ink-text hover:bg-surface-raised',
    ].join(' '),
};

const sizeClasses: Record<string, string> = {
    sm: 'h-9 px-4 text-xs gap-1.5',
    md: 'h-11 px-5 text-sm gap-2',
    lg: 'h-12 px-7 text-base gap-2.5',
};

const baseClasses = [
    'relative inline-flex items-center justify-center',
    'font-medium tracking-wide rounded-md',
    'cursor-pointer select-none whitespace-nowrap',
    'transition-all duration-200 ease-out',
    'disabled:opacity-50 disabled:cursor-not-allowed',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-calm focus-visible:ring-offset-2 focus-visible:ring-offset-ink',
    variantClasses[variant],
    sizeClasses[size],
    isFullWidth ? 'w-full' : '',
    className,
];

const elementProps =
    Tag === 'a'
        ? { href: href ?? '#', target, rel: target === '_blank' ? 'noopener noreferrer' : rel }
        : { type };
---

<Tag class:list={baseClasses} {...elementProps}>
    {iconLeft && (
        <i class:list={[iconLeft, 'text-current']} aria-hidden="true"></i>
    )}
    <span>{label}</span>
    {iconRight && (
        <i class:list={[iconRight, 'text-current']} aria-hidden="true"></i>
    )}
</Tag>
