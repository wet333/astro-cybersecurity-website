---
interface Props {
    variant?: 'primary' | 'gradient' | 'ghost' | 'outline' | 'accent' | 'light';
    size?: 'sm' | 'md' | 'lg';
    as?: 'button' | 'a';
    type?: 'button' | 'submit' | 'reset';
    href?: string;
    isFullWidth?: boolean;
    label: string;
    iconLeft?: string;
    iconRight?: string;
    class?: string;
    target?: string;
    rel?: string;
}

const {
    variant = 'primary',
    size = 'md',
    as: Tag = 'button',
    type = 'button',
    href,
    isFullWidth = false,
    label,
    iconLeft,
    iconRight,
    class: className = '',
    target,
    rel,
} = Astro.props;

const variantClasses: Record<string, string> = {
    primary: [
        'bg-primary/15 text-primary border border-primary/40',
        'hover:bg-primary/25 hover:border-primary hover:shadow-glow',
        '-translate-y-0 hover:-translate-y-0.5',
    ].join(' '),
    gradient: [
        'bg-gradient-to-r from-primary to-accent text-white border border-white/10',
        'shadow-glow hover:shadow-[0_0_36px_rgba(120,187,237,0.45)]',
        'hover:saturate-110 -translate-y-0 hover:-translate-y-0.5',
    ].join(' '),
    ghost: [
        'bg-transparent text-font/80 border border-transparent',
        'hover:text-primary hover:bg-primary/5',
    ].join(' '),
    outline: [
        'bg-transparent text-primary border border-primary/40',
        'hover:bg-primary/10 hover:border-primary/60 hover:shadow-glow-sm',
    ].join(' '),
    accent: [
        'bg-accent/15 text-accent border border-accent/40',
        'hover:bg-accent/25 hover:border-accent hover:shadow-glow-accent',
        '-translate-y-0 hover:-translate-y-0.5',
    ].join(' '),
    light: [
        'bg-white text-bg-color border border-white/20 font-semibold',
        'hover:bg-white/90 hover:shadow-[0_0_24px_rgba(255,255,255,0.25)]',
        '-translate-y-0 hover:-translate-y-0.5',
    ].join(' '),
};

const sizeClasses: Record<string, string> = {
    sm: 'px-3.5 py-2 text-xs gap-1.5',
    md: 'px-6 py-3 text-sm gap-2',
    lg: 'px-8 py-3.5 text-base gap-2.5',
};

const baseClasses = [
    'group relative inline-flex items-center justify-center',
    'font-medium tracking-wide',
    'rounded-md',
    'transition-all duration-300 ease-out',
    'cursor-pointer select-none whitespace-nowrap',
    'disabled:opacity-50 disabled:cursor-not-allowed',
    'focus-visible:ring-2 focus-visible:ring-primary/60 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-color',
    variantClasses[variant],
    sizeClasses[size],
    isFullWidth ? 'w-full' : '',
    className,
];

const elementProps =
    Tag === 'a'
        ? { href: href ?? '#', target, rel: target === '_blank' ? 'noopener noreferrer' : rel }
        : { type };
---

<Tag class:list={baseClasses} {...elementProps}>
    {iconLeft && (
        <i class:list={[iconLeft, 'text-current transition-transform duration-300 group-hover:-translate-x-0.5']} aria-hidden="true"></i>
    )}
    <span>{label}</span>
    {iconRight && (
        <i class:list={[iconRight, 'text-current transition-transform duration-300 group-hover:translate-x-0.5']} aria-hidden="true"></i>
    )}
</Tag>
