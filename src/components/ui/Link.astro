---
interface Props {
    href: string;
    variant?: 'default' | 'nav' | 'footer';
    external?: boolean;
    class?: string;
}

const { href, variant = 'default', external = false, class: className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
    default: 'text-ink-text/80 hover:text-calm transition-colors duration-200',
    nav: 'text-ink-text/85 hover:text-calm transition-colors duration-200 text-mono text-sm uppercase tracking-wider',
    footer: 'text-ink-muted hover:text-calm transition-colors duration-200 text-sm',
};
---

<a
    href={href}
    class:list={[variantClasses[variant], className]}
    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
    <slot />
</a>
