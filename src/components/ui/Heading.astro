---
type HeadingTag = 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';

interface Props {
    level?: 1 | 2 | 3 | 4 | 5 | 6;
    size?: 'display' | 'h1' | 'h2' | 'h3' | 'h4' | 'eyebrow';
    color?: 'default' | 'calm' | 'alert' | 'muted' | 'gradient';
    as?: HeadingTag;
    class?: string;
}

const {
    level = 2,
    size,
    color = 'default',
    as: Tag,
    class: className = '',
}: Props = Astro.props;

const defaultSizeMap: Record<number, string> = {
    1: 'h1',
    2: 'h2',
    3: 'h3',
    4: 'h4',
    5: 'h4',
    6: 'h4',
};

const effectiveSize = size ?? defaultSizeMap[level];
const ResolvedTag: HeadingTag = Tag ?? (`h${level}` as HeadingTag);

const sizeClasses: Record<string, string> = {
    display: 'text-[clamp(2.5rem,5vw+1rem,4.5rem)] font-extrabold leading-[1.05] tracking-[-0.025em]',
    h1: 'text-[clamp(2rem,3vw+1rem,3rem)] font-bold leading-[1.1] tracking-[-0.02em]',
    h2: 'text-[clamp(1.5rem,2vw+0.75rem,2.25rem)] font-bold leading-[1.15] tracking-[-0.02em]',
    h3: 'text-xl sm:text-2xl font-semibold leading-snug tracking-[-0.01em]',
    h4: 'text-base sm:text-lg font-semibold leading-snug',
    eyebrow: 'text-xs sm:text-sm font-medium uppercase tracking-[0.18em] text-mono',
};

const colorClasses: Record<string, string> = {
    default: 'text-ink-text',
    calm: 'text-calm',
    alert: 'text-alert',
    muted: 'text-ink-muted',
    gradient: 'text-gradient',
};
---

<ResolvedTag class:list={['font-display', sizeClasses[effectiveSize], colorClasses[color], className]}>
    <slot />
</ResolvedTag>
