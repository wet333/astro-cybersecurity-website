---
interface Props {
    variant?: 'default' | 'calm' | 'alert' | 'success' | 'muted' | 'solid';
    size?: 'sm' | 'md';
    glow?: boolean;
    class?: string;
}

const { variant = 'default', size = 'sm', glow = false, class: className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
    default: 'bg-surface-raised text-ink-muted border-border',
    calm: 'bg-calm/10 text-calm border-calm/30',
    alert: 'bg-alert/10 text-alert border-alert/30',
    success: 'bg-alert/10 text-alert-soft border-alert/30',
    muted: 'bg-surface-raised text-ink-dim border-border',
    solid: 'bg-alert text-white border-transparent font-semibold',
};

const sizeClasses: Record<string, string> = {
    sm: 'text-[0.7rem] px-2.5 py-1',
    md: 'text-xs px-3 py-1.5',
};

const glowClasses = glow ? 'shadow-glow-alert-md ring-1 ring-white/15' : '';
---

<span
    class:list={[
        'inline-flex items-center gap-1.5 border rounded-full text-mono uppercase tracking-wider',
        variantClasses[variant],
        sizeClasses[size],
        glowClasses,
        className,
    ]}
>
    <slot />
</span>
