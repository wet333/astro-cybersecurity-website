---
interface Props {
    variant?: 'default' | 'primary' | 'accent' | 'success' | 'muted' | 'solid';
    size?: 'sm' | 'md';
    glow?: boolean;
    class?: string;
}

const { variant = 'default', size = 'sm', glow = false, class: className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
    default: 'bg-surface-light/60 text-font/80 border-primary/20',
    primary: 'bg-primary/10 text-primary border-primary/40',
    accent: 'bg-accent/10 text-accent border-accent/40',
    success: 'bg-emerald-500/10 text-emerald-300 border-emerald-500/40',
    muted: 'bg-white/5 text-font/60 border-white/10',
    solid: 'bg-gradient-to-r from-primary to-accent text-white border-transparent font-semibold',
};

const sizeClasses: Record<string, string> = {
    sm: 'text-[0.7rem] px-2.5 py-1',
    md: 'text-xs px-3 py-1.5',
};

const glowClasses = glow ? 'shadow-glow ring-1 ring-white/20' : '';
---

<span
    class:list={[
        'inline-flex items-center gap-1.5 border rounded-full text-mono uppercase tracking-wider',
        variantClasses[variant],
        sizeClasses[size],
        glowClasses,
        className,
    ]}
>
    <slot />
</span>
