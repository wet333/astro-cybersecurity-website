---
import Logo from '../ui/Logo.astro';

interface NavItem {
    label: string;
    href: string;
}

interface Props {
    items: NavItem[];
    class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<div
    id="mobile-menu"
    data-mobile-menu
    class:list={[
        'fixed inset-0 z-40 lg:hidden',
        'backdrop-blur-glass bg-ink/95',
        'pointer-events-none opacity-0',
        'transition-opacity duration-300',
        className,
    ]}
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-menu-heading"
    aria-hidden="true"
>
    <div class="flex items-center justify-between h-16 sm:h-20 px-6 sm:px-8 border-b border-border">
        <Logo size="sm" />
        <button
            type="button"
            data-mobile-menu-close
            aria-label="Close menu"
            class="inline-flex items-center justify-center h-10 w-10 rounded-md text-ink-text hover:text-calm hover:bg-surface-raised transition-colors"
        >
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
    </div>

    <h2 id="mobile-menu-heading" class="sr-only">Menu</h2>

    <nav
        class="flex flex-col items-center justify-center gap-2 px-6"
        style="min-height: calc(100vh - 5rem)"
        aria-label="Mobile primary"
    >
        {items.map((item) => (
            <a
                href={item.href}
                data-mobile-menu-link
                class="block py-4 text-2xl font-display font-semibold text-ink-text hover:text-calm transition-colors"
            >
                {item.label}
            </a>
        ))}
    </nav>

    <div class="absolute bottom-0 left-0 right-0 px-6 sm:px-8 py-6 bg-ink/80 border-t border-border">
        <p class="text-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-dim mb-3">
            Direct contact
        </p>
        <slot name="footer" />
    </div>
</div>
