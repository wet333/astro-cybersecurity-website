---
interface Props {
    href: string;
    class?: string;
}

const { href, class: className = '' } = Astro.props;
---

<a
    href={href}
    class:list={[
        'relative text-mono text-sm uppercase tracking-wider transition-colors duration-200 hover:text-calm focus:text-calm',
        className,
    ]}
>
    <slot />
</a>
