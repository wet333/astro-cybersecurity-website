---
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';

const faqs = [
    {
        q: 'How fast can Cybershield respond to an active incident?',
        a: 'Our incident response team is on call 24/7. Acknowledgement within 15 minutes, mitigation steps usually begin within an hour. For active breaches, call the hotline in the Contact section.',
    },
    {
        q: 'Do you work with small teams or only enterprise?',
        a: 'Both. Our Pro and Basic plans are designed for teams of 5–250, and our Enterprise tier scales to multi-thousand-employee organizations with dedicated security staff.',
    },
    {
        q: 'Can you integrate with the tools we already use?',
        a: 'Yes. We have first-party integrations for AWS, Azure, GCP, Okta, Microsoft 365, Google Workspace, CrowdStrike, Splunk, Datadog, and most major SIEM/SOAR platforms. Custom integrations available on Enterprise.',
    },
    {
        q: 'What compliance frameworks do you support?',
        a: 'SOC 2, ISO 27001, HIPAA, PCI DSS, GDPR, and NIST 800-53. Compliance consulting is included with the Pro and Enterprise tiers.',
    },
    {
        q: 'Is penetration testing included?',
        a: 'Annual penetration testing is included with the Pro and Enterprise plans. Basic customers can purchase one-off engagements at any time.',
    },
    {
        q: 'How is pricing structured?',
        a: 'Per-seat monthly with annual discounts available. There are no hidden fees for support, basic integrations, or core monitoring.',
    },
];
---

<Section id="faq-section" background="none" divider="top" separator>
    <Container>
        <div class="max-w-2xl mb-12" data-reveal>
            <Eyebrow prefix="06 /">FAQ</Eyebrow>
            <Heading level={2} size="h1" class="mt-3">
                Answers before
                <span class="text-gradient">you ask</span>.
            </Heading>
        </div>

        <div class="flex flex-col gap-4" data-reveal data-reveal-delay={50}>
            {faqs.map((faq, i) => (
                <details
                    class="group glass p-5 sm:p-6 transition-all duration-300 hover:border-primary/40 cursor-pointer"
                >
                    <summary class="flex items-start gap-4 cursor-pointer list-none">
                        <span class="text-mono text-xs text-primary mt-1.5 flex-shrink-0">
                            Q.{String(i + 1).padStart(2, '0')}
                        </span>
                        <Heading level={3} size="h4" class="flex-1 pr-2">
                            {faq.q}
                        </Heading>
                        <div class="flex-shrink-0 h-7 w-7 rounded border border-primary/30 flex items-center justify-center text-primary transition-transform duration-300 group-open:rotate-45">
                            <i class="fa-solid fa-plus text-xs" aria-hidden="true"></i>
                        </div>
                    </summary>
                    <div class="mt-4 pl-9 border-l-2 border-primary/30 ml-1.5">
                        <Text size="sm" color="muted" class="pl-4">
                            {faq.a}
                        </Text>
                    </div>
                </details>
            ))}
        </div>
    </Container>
</Section>
