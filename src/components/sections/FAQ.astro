---
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';

const faqs = [
    {
        q: 'How fast can Cybershield respond to an active incident?',
        a: 'Our incident response team is on call 24/7. Acknowledgement within 15 minutes, mitigation steps usually begin within an hour. For active breaches, call the hotline in the Contact section.',
    },
    {
        q: 'Do you work with small teams or only enterprise?',
        a: 'Both. Pro is designed for teams of 5–250, and Enterprise scales to multi-thousand-employee organizations with dedicated security staff.',
    },
    {
        q: 'Can you integrate with the tools we already use?',
        a: 'Yes. We have first-party integrations for AWS, Azure, GCP, Okta, Microsoft 365, Google Workspace, CrowdStrike, Splunk, Datadog, and most major SIEM/SOAR platforms. Custom integrations available on Enterprise.',
    },
    {
        q: 'What compliance frameworks do you support?',
        a: 'SOC 2, ISO 27001, HIPAA, PCI DSS, GDPR, and NIST 800-53. Compliance consulting is included with the Pro and Enterprise tiers.',
    },
    {
        q: 'Is penetration testing included?',
        a: 'Annual penetration testing is included with Pro and Enterprise. Basic customers can purchase one-off engagements at any time.',
    },
    {
        q: 'How is pricing structured?',
        a: 'Per-seat monthly with annual discounts available. There are no hidden fees for support, basic integrations, or core monitoring.',
    },
];
---

<Section id="faq-section" background="dots">
    <Container>
        <div class="max-w-2xl mb-14" data-reveal>
            <Eyebrow color="calm" number="05">FAQ</Eyebrow>
            <Heading level={2} size="h1" class="mt-4">
                Answers before
                <span class="text-gradient">you ask</span>.
            </Heading>
        </div>

        <div class="max-w-3xl flex flex-col gap-3" data-reveal data-reveal-delay="50">
            {faqs.map((faq) => (
                <details
                    class="group bg-surface border border-border rounded-card overflow-hidden transition-colors duration-200 hover:border-border-active"
                >
                    <summary class="flex items-start sm:items-center gap-4 p-5 sm:p-6 cursor-pointer list-none">
                        <span class="flex-shrink-0 inline-flex h-7 w-7 items-center justify-center rounded-md bg-surface-raised border border-border text-mono text-[0.7rem] font-semibold text-ink-muted group-open:border-calm/50 group-open:text-calm transition-colors">
                            ?
                        </span>
                        <Heading level={3} size="h4" class="flex-1 pr-2 text-ink-text font-medium">
                            {faq.q}
                        </Heading>
                        <div class="flex-shrink-0 h-7 w-7 rounded-md border border-border flex items-center justify-center text-ink-muted group-open:border-calm/50 group-open:text-calm group-open:rotate-45 transition-all duration-200">
                            <i class="fa-solid fa-plus text-xs" aria-hidden="true"></i>
                        </div>
                    </summary>
                    <div class="px-5 sm:px-6 pb-5 sm:pb-6 pt-1 pl-[3.75rem] sm:pl-[4.25rem]">
                        <Text size="base" color="muted">{faq.a}</Text>
                    </div>
                </details>
            ))}
        </div>
    </Container>
</Section>
