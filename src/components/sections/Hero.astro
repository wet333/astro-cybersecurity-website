---
import NavBar from '~/components/nav/NavBar.astro';
import Button from '~/components/ui/Button.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import Text from '~/components/ui/Text.astro';
---

<section class="relative w-full min-h-[100svh] flex flex-col overflow-hidden">
    <!-- Soft vignette behind the heading -->
    <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse 60% 50% at 30% 50%, rgba(120,187,237,0.10) 0%, transparent 60%);"
        aria-hidden="true"
    ></div>

    <!-- Radar / sonar ping (decorative, hidden on mobile) -->
    <div class="hero-radar hidden lg:block" aria-hidden="true">
        <div class="ping-ring"></div>
        <div class="ping-ring"></div>
        <div class="ping-ring"></div>
        <!-- Center dot -->
        <div class="radar-center"></div>
    </div>

    <NavBar />

    <div class="relative z-10 flex-1 flex items-center divider-bottom" data-reveal>
        <Container size="lg">
            <div class="max-w-3xl">
                <Eyebrow prefix="//">
                    Cybershield · Threat Defense Platform
                </Eyebrow>
                <Heading level={1} size="display" class="mt-3">
                    Security that
                    <span class="text-gradient">thinks ahead</span>
                    of the threat.
                </Heading>
                <Text size="lead" color="muted" class="mt-6 max-w-2xl">
                    We provide top-notch cybersecurity services to protect your
                    business from modern threats — combining proactive monitoring,
                    ethical hacking, and 24/7 incident response.
                </Text>
                <div class="mt-10 flex flex-wrap items-center gap-4">
                    <Button
                        label="Let us help you"
                        variant="gradient"
                        size="lg"
                        href="#contact-section"
                        as="a"
                        iconRight="fa-solid fa-arrow-right"
                    />
                    <Button
                        label="See our work"
                        variant="outline"
                        size="lg"
                        href="#case-studies-section"
                        as="a"
                    />
                </div>
            </div>
        </Container>
    </div>

    <!-- Scroll hint -->
    <div class="relative z-10 pb-16 flex justify-center" aria-hidden="true">
        <div class="flex flex-col items-center gap-2 mt-4 text-font/40 text-mono text-xs uppercase tracking-wider">
            <span>Scroll</span>
            <i class="fa-solid fa-chevron-down text-primary animate-scroll-hint"></i>
        </div>
    </div>
</section>

<style>
    .hero-radar {
        position: absolute;
        top: 50%;
        right: max(2rem, calc((100vw - 1280px) / 2 + 2rem));
        transform: translateY(-50%);
        width: 480px;
        height: 480px;
        pointer-events: none;
        z-index: 0;
    }

    .ping-ring {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 320px;
        height: 320px;
        margin-top: -160px;
        margin-left: -160px;
        border-radius: 9999px;
        border: 2px solid rgba(var(--primary-color-rgb), 0.6);
        transform: scale(0.2);
        opacity: 0;
        animation: ping 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }

    .ping-ring:nth-child(1) { animation-delay: 0s; }
    .ping-ring:nth-child(2) { animation-delay: 1s; }
    .ping-ring:nth-child(3) { animation-delay: 2s; }

    .radar-center {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 12px;
        height: 12px;
        margin-top: -6px;
        margin-left: -6px;
        border-radius: 9999px;
        background: var(--primary-color);
        box-shadow:
            0 0 12px rgba(var(--primary-color-rgb), 0.8),
            0 0 24px rgba(var(--primary-color-rgb), 0.4);
        animation: radar-pulse 2s ease-in-out infinite;
    }

    @keyframes ping {
        0%   { transform: scale(0.2); opacity: 0.7; }
        100% { transform: scale(1.8); opacity: 0; }
    }

    @keyframes radar-pulse {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.5; }
    }

    @media (max-width: 1280px) {
        .hero-radar {
            width: 400px;
            height: 400px;
        }
        .ping-ring {
            width: 260px;
            height: 260px;
            margin-top: -130px;
            margin-left: -130px;
        }
    }
</style>
