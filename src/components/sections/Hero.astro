---
import Button from '~/components/ui/Button.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import RefinedRadar from '~/components/ui/RefinedRadar.astro';
import StatusTicker from '~/components/ui/StatusTicker.astro';
import Text from '~/components/ui/Text.astro';
import TrustedBy from '~/components/ui/TrustedBy.astro';
import contactData from '~/data/contacts.json';
---

<section class="relative w-full min-h-[100svh] flex flex-col overflow-hidden">
    <!-- Ambient glows + grid, wrapped in a fade-mask so the alert glow
         at the bottom-left softens into the next section instead of
         stopping at a hard edge. -->
    <div class="bg-fade-bottom absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute inset-0 bg-glow-both"></div>
        <div class="absolute inset-0 bg-grid opacity-50"></div>
    </div>

    <div class="relative z-10 flex-1 flex items-center pt-20 sm:pt-24">
        <Container size="lg">
            <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-16 items-center">
                <!-- Left: text -->
                <div class="max-w-2xl" data-reveal>
                    <Eyebrow color="calm" number="//">
                        Cybershield · Threat Defense Platform
                    </Eyebrow>

                    <div class="mt-3 flex flex-col gap-1.5">
                        <span class="text-mono text-[0.65rem] sm:text-xs uppercase tracking-[0.18em] text-ink-dim font-medium">
                            Trusted by security teams at
                        </span>
                        <TrustedBy />
                    </div>

                    <Heading level={1} size="display" class="mt-7">
                        We stop the breach your firewall
                        <span class="block text-gradient italic font-medium">won't see.</span>
                    </Heading>

                    <Text size="lead" color="muted" class="mt-6 max-w-xl">
                        Proactive cybersecurity for businesses that can't afford
                        to be the next headline. Threat hunting, ethical hacking,
                        and 24/7 incident response — handled by people who've
                        worked the other side.
                    </Text>

                    <div class="mt-8 flex flex-wrap items-center gap-3">
                        <Button
                            label="Get a threat assessment"
                            variant="cta"
                            size="lg"
                            href="#contact-section"
                            as="a"
                            iconRight="fa-solid fa-arrow-right"
                        />
                        <Button
                            label="Call our 24/7 hotline"
                            variant="outline"
                            size="lg"
                            href={`tel:${contactData.phone}`}
                            as="a"
                            iconLeft="fa-solid fa-phone"
                        />
                    </div>

                    <div class="mt-10">
                        <StatusTicker />
                    </div>
                </div>

                <!-- Right: radar -->
                <div class="hidden lg:block" data-reveal data-reveal-delay="150">
                    <RefinedRadar />
                </div>
            </div>
        </Container>
    </div>

    <!-- Mobile radar (smaller, below content) -->
    <div class="lg:hidden relative z-10 pb-12 px-6">
        <div class="max-w-sm mx-auto" data-reveal data-reveal-delay="200">
            <RefinedRadar />
        </div>
    </div>

    <!-- Scroll hint -->
    <div class="relative z-10 pb-8 flex justify-center" aria-hidden="true">
        <div class="flex flex-col items-center gap-2 text-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-dim">
            <span>Scroll</span>
            <i class="fa-solid fa-chevron-down text-ink-muted animate-scroll-hint"></i>
        </div>
    </div>
</section>
