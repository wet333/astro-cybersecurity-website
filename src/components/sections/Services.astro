---
import Card from '~/components/ui/Card.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';
import services from '~/data/serviceList.json';
import type { Service } from '~/types';

type EnrichedService = Service & { icon: string; tier: string };

const iconMap: Record<number, { icon: string; tier: string }> = {
    0: { icon: 'fa-code',             tier: 'Add-on' },
    1: { icon: 'fa-sliders',          tier: 'Included in Pro' },
    2: { icon: 'fa-plug',             tier: 'Included in Pro' },
    3: { icon: 'fa-database',         tier: 'Enterprise' },
    4: { icon: 'fa-book',             tier: 'Included in Pro' },
    5: { icon: 'fa-cloud',            tier: 'Enterprise' },
    6: { icon: 'fa-user-shield',      tier: 'Enterprise' },
    7: { icon: 'fa-table-cells',      tier: 'Included in Pro' },
};

const list: EnrichedService[] = (services as Service[]).map((s, i) => ({
    ...s,
    icon: iconMap[i]?.icon ?? 'fa-shield-halved',
    tier: iconMap[i]?.tier ?? 'Add-on',
}));

const featured = [0, 3, 6]; // indices that span 2 columns in the bento
---

<Section id="services-section" background="grid-fine">
    <Container>
        <div class="max-w-2xl mb-14" data-reveal>
            <Eyebrow color="calm" number="02">Capabilities</Eyebrow>
            <Heading level={2} size="h1" class="mt-4">
                A full-stack defense,
                <span class="text-gradient">modular by design</span>.
            </Heading>
            <Text size="lead" color="muted" class="mt-5">
                Pick the components you need. Pay only for what protects you.
            </Text>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
            {list.map((service, i) => (
                <div
                    class:list={[
                        featured.includes(i) ? 'sm:col-span-2 lg:col-span-2' : '',
                    ]}
                    data-reveal
                    data-reveal-delay={i * 60}
                >
                    <Card tone="subtle" hover class="h-full flex flex-col gap-5 group">
                        <div class="flex items-start justify-between">
                            <div class="inline-flex items-center justify-center h-12 w-12 rounded-md bg-surface-raised border border-border text-calm group-hover:border-calm/60 group-hover:shadow-glow-sm transition-all duration-200">
                                <i class:list={['fa-solid', service.icon, 'text-lg']} aria-hidden="true"></i>
                            </div>
                            <span class="text-mono text-[0.7rem] text-ink-dim uppercase tracking-[0.18em]">
                                {String(i + 1).padStart(2, '0')}
                            </span>
                        </div>
                        <div class="flex-1">
                            <Heading level={3} size="h4" class="text-ink-text">
                                {service.title}
                            </Heading>
                            <Text size="base" color="muted" class="mt-3">
                                {service.description}
                            </Text>
                        </div>
                        <div class="pt-4 border-t border-border flex items-center justify-between text-mono text-[0.7rem] uppercase tracking-[0.18em]">
                            <span class="text-ink-dim">Tier</span>
                            <span class="text-calm">{service.tier}</span>
                        </div>
                    </Card>
                </div>
            ))}
        </div>
    </Container>
</Section>
