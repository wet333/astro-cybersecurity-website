---
import Badge from '~/components/ui/Badge.astro';
import Card from '~/components/ui/Card.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';
import caseStudies from '~/data/caseStudies.json';
import type { CaseStudy as CaseStudyType } from '~/types';

const items = caseStudies as CaseStudyType[];
---

<Section id="case-studies-section" background="none" divider="top" separator>
    <Container>
        <div class="max-w-2xl mb-12" data-reveal>
            <Eyebrow prefix="03 /">Field Reports</Eyebrow>
            <Heading level={2} size="h1" class="mt-3">
                Real threats.
                <span class="text-gradient">Real outcomes.</span>
            </Heading>
        </div>

        <div class="space-y-4">
            {items.map((study, i) => (
                <details
                    name="case-studies"
                    class="group glass overflow-hidden transition-all duration-300 hover:border-primary/40"
                    data-reveal
                    data-reveal-delay={i * 80}
                >
                    <summary class="flex items-center gap-4 p-5 sm:p-6 cursor-pointer list-none">
                        <div class="flex-shrink-0 h-10 w-10 rounded border border-primary/30 bg-primary/10 text-primary flex items-center justify-center text-mono text-sm">
                            {String(i + 1).padStart(2, '0')}
                        </div>
                        <div class="flex-1 min-w-0">
                            <Heading level={3} size="h4" class="truncate">
                                {study.title}
                            </Heading>
                            <p class="text-mono text-xs uppercase tracking-wider text-font/50 mt-1 truncate">
                                {study.clientProfile.name} · {study.clientProfile.industry}
                            </p>
                        </div>
                        <Badge variant="primary">{study.clientProfile.industry}</Badge>
                        <div class="flex-shrink-0 h-9 w-9 rounded border border-primary/30 flex items-center justify-center text-primary transition-transform duration-300 group-open:rotate-45">
                            <i class="fa-solid fa-plus text-sm" aria-hidden="true"></i>
                        </div>
                    </summary>
                    <div class="px-5 sm:px-6 pb-6 pt-2 border-t border-primary/15">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10 mt-4">
                            <div>
                                <img
                                    src={study.image}
                                    alt={study.title}
                                    class="w-full h-48 object-cover rounded border border-primary/20"
                                    loading="lazy"
                                />
                                <div class="mt-4 space-y-1.5">
                                    <p class="text-mono text-xs uppercase tracking-wider text-primary mb-2">
                                        Client profile
                                    </p>
                                    {Object.entries(study.clientProfile).map(([key, value]) => (
                                        <div class="flex justify-between text-sm gap-4">
                                            <span class="text-mono text-font/60 capitalize">
                                                {key.replace(/([A-Z])/g, ' $1').trim()}
                                            </span>
                                            <span class="text-font/90 text-right">
                                                {value}
                                            </span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                            <div class="space-y-4">
                                <div>
                                    <p class="text-mono text-xs uppercase tracking-wider text-primary mb-2">
                                        Challenge
                                    </p>
                                    <Text size="sm" color="muted">{study.challenge}</Text>
                                </div>
                                <div>
                                    <p class="text-mono text-xs uppercase tracking-wider text-primary mb-2">
                                        Solution
                                    </p>
                                    <ul class="space-y-1.5">
                                        {study.solution.map((item) => (
                                            <li class="flex items-start gap-2 text-sm text-font/85">
                                                <i class="fa-solid fa-circle-check text-primary mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                                                <span>{item}</span>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                                <div>
                                    <p class="text-mono text-xs uppercase tracking-wider text-accent mb-2">
                                        Results
                                    </p>
                                    <ul class="space-y-1.5">
                                        {study.results.map((item) => (
                                            <li class="flex items-start gap-2 text-sm text-font/85">
                                                <i class="fa-solid fa-arrow-trend-up text-accent mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                                                <span>{item}</span>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </details>
            ))}
        </div>
    </Container>
</Section>
