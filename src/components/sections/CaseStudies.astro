---
import Badge from '~/components/ui/Badge.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';
import caseStudies from '~/data/caseStudies.json';
import type { CaseStudy as CaseStudyType } from '~/types';

type Outcome = { value: string; label: string };

const items = (caseStudies as CaseStudyType[]).map((study) => {
    const industry = String(study.clientProfile.industry ?? '');
    let outcome: Outcome;
    if (industry.includes('Industrial')) {
        outcome = { value: '−78%', label: 'security incidents in year one' };
    } else if (industry.includes('Financial')) {
        outcome = { value: '0', label: 'breaches in 18 months following deployment' };
    } else {
        outcome = { value: '−99.7%', label: 'unauthorized access attempts' };
    }
    return { study, outcome };
});
---

<Section id="case-studies-section" background="none">
    <Container>
        <div class="max-w-2xl mb-14" data-reveal>
            <Eyebrow color="calm" number="03">Field Reports</Eyebrow>
            <Heading level={2} size="h1" class="mt-4">
                Real threats.
                <span class="text-gradient">Real outcomes.</span>
            </Heading>
        </div>

        <div class="flex flex-col gap-5 sm:gap-6">
            {items.map(({ study, outcome }, i) => (
                <article
                    class="group relative bg-surface border border-border rounded-card overflow-hidden transition-colors duration-200 hover:border-border-active"
                    data-reveal
                    data-reveal-delay={i * 80}
                >
                    <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr]">
                        <!-- Image (pure visual) + client profile panel below -->
                        <div class="flex flex-col">
                            <div class="relative min-h-[260px] lg:flex-1 bg-surface-raised">
                                <img
                                    src={study.image}
                                    alt={study.title}
                                    class="absolute inset-0 h-full w-full object-cover"
                                    loading="lazy"
                                />
                            </div>
                            <div class="bg-surface-raised border-t border-border p-5 sm:p-6 flex flex-col gap-2.5">
                                <Badge variant="calm" size="sm">
                                    {study.clientProfile.industry}
                                </Badge>
                                <p class="font-display font-semibold text-base sm:text-lg text-ink-text leading-tight">
                                    {study.clientProfile.name}
                                </p>
                                <div class="flex flex-wrap gap-x-4 gap-y-1 text-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-muted">
                                    {Object.entries(study.clientProfile)
                                        .filter(([k]) => k !== 'name' && k !== 'industry')
                                        .slice(0, 3)
                                        .map(([k, v]) => (
                                            <span>
                                                <span class="text-ink-dim">{k.replace(/([A-Z])/g, ' $1').trim()}:</span>{' '}
                                                <span class="text-ink-text">{v}</span>
                                            </span>
                                        ))}
                                </div>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-6 sm:p-8 lg:p-10 flex flex-col gap-6">
                            <Heading level={3} size="h3" class="text-ink-text leading-tight">
                                {study.title}
                            </Heading>

                            <!-- Big-number outcome callout -->
                            <div class="flex items-baseline gap-4 sm:gap-5 pb-6 border-b border-border">
                                <span class="font-display text-[clamp(2.75rem,6vw,4rem)] font-extrabold text-alert leading-none tracking-[-0.03em] tabular-nums">
                                    {outcome.value}
                                </span>
                                <span class="text-ink-muted text-sm sm:text-base leading-snug">
                                    {outcome.label}
                                </span>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div>
                                    <p class="text-mono text-[0.7rem] uppercase tracking-[0.18em] text-calm mb-3">
                                        Challenge
                                    </p>
                                    <Text size="sm" color="muted">{study.challenge}</Text>
                                </div>
                                <div class="space-y-5">
                                    <div>
                                        <p class="text-mono text-[0.7rem] uppercase tracking-[0.18em] text-calm mb-3">
                                            Solution
                                        </p>
                                        <ul class="space-y-2">
                                            {study.solution.slice(0, 3).map((item) => (
                                                <li class="flex items-start gap-2.5 text-sm text-ink-text/85">
                                                    <i class="fa-solid fa-circle-check text-calm mt-1 flex-shrink-0 text-xs" aria-hidden="true"></i>
                                                    <span>{item}</span>
                                                </li>
                                            ))}
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </Container>
</Section>
