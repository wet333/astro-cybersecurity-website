---
import Button from '~/components/ui/Button.astro';
import Card from '~/components/ui/Card.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import FormField from '~/components/ui/FormField.astro';
import Heading from '~/components/ui/Heading.astro';
import NextSteps from '~/components/ui/NextSteps.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';
import ContactCard from './ContactCard.astro';
import contactData from '~/data/contacts.json';
import type { ContactData } from '~/types';

const contact = contactData as ContactData;
---

<Section id="contact-section" background="glow-center">
    <Container>
        <div class="max-w-2xl mb-14" data-reveal>
            <Eyebrow color="alert" number="06">Talk to us</Eyebrow>
            <Heading level={2} size="h1" class="mt-4">
                Let's map your
                <span class="text-gradient">attack surface</span>.
            </Heading>
            <Text size="lead" color="muted" class="mt-5">
                Have a question or want a threat assessment? Send a message and
                we'll get back within one business day.
            </Text>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <!-- Form (8 cols) -->
            <Card tone="subtle-strong" class="lg:col-span-8 flex flex-col" data-reveal>
                <form name="contact" method="POST" data-netlify="true" class="flex flex-col flex-1 gap-5 min-h-0">
                    <input type="hidden" name="form-name" value="contact" />
                    <FormField id="name" name="name" label="Name" required autocomplete="name" />
                    <FormField
                        id="email"
                        name="email"
                        type="email"
                        label="Email"
                        required
                        autocomplete="email"
                    />
                    <FormField
                        id="phone"
                        name="phone"
                        type="tel"
                        label="Phone (optional)"
                        autocomplete="tel"
                    />
                    <FormField
                        id="message"
                        name="message"
                        label="Message"
                        multiline
                        grow
                        required
                        rows={4}
                        placeholder="Tell us about your environment and what you're trying to protect..."
                    />
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-2 mt-auto">
                        <p class="text-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-dim">
                            We respect your privacy. No spam, ever.
                        </p>
                        <Button
                            type="submit"
                            label="Send message"
                            variant="cta"
                            iconRight="fa-solid fa-paper-plane"
                        />
                    </div>
                </form>
            </Card>

            <!-- Sidebar: Next steps + contact info (4 cols) -->
            <div class="lg:col-span-4 flex flex-col gap-5" data-reveal data-reveal-delay="150">
                <Card tone="subtle-strong" class="flex-1">
                    <NextSteps />
                </Card>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-3">
                    <ContactCard icon="fa-phone" label="24/7 hotline">
                        <a
                            href={`tel:${contact.phone}`}
                            class="text-ink-text hover:text-alert transition-colors"
                        >
                            {contact.phone}
                        </a>
                    </ContactCard>
                    <ContactCard icon="fa-regular fa-envelope" label="Email">
                        <a
                            href={`mailto:${contact.email}`}
                            class="text-ink-text hover:text-calm transition-colors break-all"
                        >
                            {contact.email}
                        </a>
                    </ContactCard>
                </div>
            </div>
        </div>
    </Container>
</Section>
