---
import Card from '~/components/ui/Card.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Grid from '~/components/ui/Grid.astro';
import Heading from '~/components/ui/Heading.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';
import aboutPageInfo from '~/data/aboutUsData.json';
---

<Section id="about-section" tone="tinted-calm" background="none">
    <Container>
        <div class="max-w-2xl mb-14" data-reveal>
            <Eyebrow color="calm" number="01">About Cybershield</Eyebrow>
            <Heading level={2} size="h1" class="mt-4">
                A team that's been on
                <span class="text-gradient">the other side</span>.
            </Heading>
        </div>

        <Grid cols={2} gap="lg" class="items-stretch">
            <div data-reveal data-reveal-delay="100">
                <div class="relative h-full min-h-[360px] overflow-hidden rounded-card border border-border group">
                    <img
                        src="/images/company-team.jpg"
                        alt="The Cybershield team at work"
                        class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                        loading="lazy"
                    />
                    <div
                        class="absolute inset-0 bg-image-fade"
                        aria-hidden="true"
                    ></div>
                    <!-- Decorative play overlay -->
                    <div class="absolute bottom-5 left-5 right-5 flex items-center gap-3">
                        <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-ink/70 border border-border backdrop-blur-glass text-ink-text group-hover:border-calm/60 group-hover:text-calm transition-colors">
                            <i class="fa-solid fa-play text-xs translate-x-px" aria-hidden="true"></i>
                        </span>
                        <div>
                            <p class="text-mono text-[0.65rem] uppercase tracking-[0.18em] text-ink-muted">Watch</p>
                            <p class="text-sm text-ink-text font-medium">A day with the team</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-6" data-reveal data-reveal-delay="200">
                <Text size="lead" color="muted">
                    {aboutPageInfo.description}
                </Text>

                <Card tone="subtle-strong" class="relative">
                    <i
                        class="fa-solid fa-quote-left absolute top-4 right-4 text-alert/30 text-2xl"
                        aria-hidden="true"
                    ></i>
                    <Text size="lg" class="italic text-ink-text/90 leading-relaxed">
                        Most of our work is invisible. That's the point.
                    </Text>
                    <p class="mt-4 text-mono text-[0.7rem] uppercase tracking-[0.18em] text-alert">
                        — {aboutPageInfo.author}
                    </p>
                </Card>
            </div>
        </Grid>
    </Container>
</Section>
