---
import Badge from '~/components/ui/Badge.astro';
import Button from '~/components/ui/Button.astro';
import Card from '~/components/ui/Card.astro';
import Container from '~/components/ui/Container.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Heading from '~/components/ui/Heading.astro';
import Section from '~/components/ui/Section.astro';
import Text from '~/components/ui/Text.astro';
import priceOptions from '~/data/pricingPlans.json';
import type { PricingPlan } from '~/types';

const plans = priceOptions as PricingPlan[];
---

<Section id="plans-section" background="none" divider="top" separator>
    <Container>
        <div class="max-w-2xl mb-12" data-reveal>
            <Eyebrow prefix="04 /">Plans & Pricing</Eyebrow>
            <Heading level={2} size="h1" class="mt-3">
                Pick your
                <span class="text-gradient">protection tier</span>.
            </Heading>
            <Text size="lead" color="muted" class="mt-5">
                All plans include a <span class="text-font font-medium">30-day money-back</span> guarantee. Cancel any time.
            </Text>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
            {plans.map((plan, i) => {
                const featured = i === 1;
                return (
                    <div
                        class:list={[
                            'relative h-full',
                            featured ? 'md:-mt-4 md:mb-0' : '',
                        ]}
                        data-reveal
                        data-reveal-delay={i * 100}
                        cursor-pointer
                    >
                        {featured && (
                            <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-10">
                                <Badge variant="solid" size="md" glow>Most popular</Badge>
                            </div>
                        )}
                        <Card
                            hover
                            glow={featured}
                            tone={featured ? 'strong' : 'default'}
                            class:list={[
                                'h-full flex flex-col gap-6',
                                featured ? 'border-primary/60' : '',
                            ]}
                        >
                            <div class="text-center pb-4 border-b border-primary/15">
                                <p class="text-mono text-xs uppercase tracking-wider text-primary font-medium">
                                    {plan.description}
                                </p>
                                <div class="mt-3 flex items-baseline justify-center gap-1">
                                    <span class="font-display text-5xl font-extrabold text-font">
                                        {plan.price}
                                    </span>
                                    <span class="text-font/60 text-sm">/month</span>
                                </div>
                            </div>

                            <ul class="space-y-3 flex-1">
                                {plan.perkList.map((perk) => (
                                    <li
                                        class:list={[
                                            'flex items-start gap-3 text-sm',
                                            perk.isActive ? 'text-font/90' : 'text-font/40',
                                        ]}
                                    >
                                        <span
                                            class:list={[
                                                'flex-shrink-0 h-5 w-5 rounded-full flex items-center justify-center text-[0.6rem] mt-0.5',
                                                perk.isActive
                                                    ? 'bg-emerald-500/15 text-emerald-300 border border-emerald-500/40'
                                                    : 'bg-white/5 text-font/30 border border-white/10',
                                            ]}
                                        >
                                            <i
                                                class:list={[
                                                    perk.isActive ? 'fa-solid fa-check' : 'fa-solid fa-xmark',
                                                ]}
                                                aria-hidden="true"
                                            ></i>
                                        </span>
                                        <span class:list={[perk.isActive ? '' : 'line-through decoration-font/20']}>
                                            {perk.name}
                                        </span>
                                    </li>
                                ))}
                            </ul>

                            <Button
                                label={plan.buttonLabel}
                                variant={featured ? 'gradient' : 'outline'}
                                size="md"
                                isFullWidth
                                as="a"
                                href="#contact-section"
                                iconRight="fa-solid fa-arrow-right"
                            />
                        </Card>
                    </div>
                );
            })}
        </div>
    </Container>
</Section>
