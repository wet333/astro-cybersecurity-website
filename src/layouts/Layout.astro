---
import '~/styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/montserrat/500.css';
import '@fontsource/montserrat/600.css';
import '@fontsource/montserrat/700.css';
import '@fontsource/montserrat/800.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fortawesome/fontawesome-free/css/all.min.css';
import NavBar from '~/components/nav/NavBar.astro';

interface Props {
    meta: {
        title: string;
        description: string;
        url?: string;
        image?: string;
    };
}

const { meta } = Astro.props;
const DEFAULT_URL = 'https://astro-cybersecurity-website.vercel.app/';
const DEFAULT_OG_IMAGE = `${DEFAULT_URL}default-og-image.png`;
const DEFAULT_TWITTER_IMAGE = `${DEFAULT_URL}default-twitter-image.png`;
const canonicalUrl = meta.url ?? DEFAULT_URL;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon/shield.png" />
        <meta name="generator" content={Astro.generator} />

        <title>{meta.title}</title>
        <meta name="description" content={meta.description} />
        <meta name="author" content="Astro Cybersecurity Team" />
        <meta name="keywords" content="cybersecurity, online security, data protection, hacking prevention, cybersecurity tools, cyber threats" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="theme-color" content="#0a0c10" />

        <!-- Open Graph Metadata -->
        <meta property="og:title" content={meta.title} />
        <meta property="og:description" content={meta.description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:type" content="website" />
        <meta property="og:image" content={meta.image ?? DEFAULT_OG_IMAGE} />

        <!-- Twitter Metadata -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={meta.title} />
        <meta name="twitter:description" content={meta.description} />
        <meta name="twitter:image" content={meta.image ?? DEFAULT_TWITTER_IMAGE} />

        <!-- Canonical Link -->
        <link rel="canonical" href={canonicalUrl} />
        <meta name="robots" content="index, follow" />
    </head>
    <body class="bg-ink text-ink-text font-sans">
        <a
            href="#main"
            class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-surface focus:border focus:border-calm focus:rounded focus:text-ink-text"
        >
            Skip to main content
        </a>

        <NavBar />

        <main id="main">
            <slot />
        </main>

        <script>
            import { initReveal } from '~/scripts/reveal';
            import { initCountUp } from '~/scripts/count-up';
            import { initMobileMenu } from '~/scripts/mobile-menu';
            import { initAccordionClick } from '~/scripts/accordion-click';

            initReveal();
            initCountUp();
            initMobileMenu();
            initAccordionClick();
        </script>
    </body>
</html>
